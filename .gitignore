# Runtime uploads and source bank files
/uploads/*
!/uploads/.gitkeep
*.ofx
*.csv

# Local environment and machine-specific configuration
.env
config/config.php
*/config/db.php

# Runtime logs and job state
/logs/*
!/logs/.gitkeep
*.log

# Python cache files
__pycache__/
*/__pycache__/*

# Migration files are source-controlled. Do not ignore /migrations/*.sql.
